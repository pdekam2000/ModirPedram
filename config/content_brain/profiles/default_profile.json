{
  "profile_id": "default_v1",
  "profile_version": "1.0.0",
  "profile_type": "base",
  "extends": null,
  "project_name": "Viral Content Brain",
  "niche": "general",
  "niche_label": "General Short-Form Content",
  "domain": "general",
  "language": "English",
  "language_rules": {
    "output_language": "English",
    "allow_mixed_language": false,
    "caption_language": "English",
    "narration_language": "English",
    "title_language": "English"
  },
  "target_platforms": [
    "tiktok",
    "youtube_shorts",
    "instagram_reels"
  ],
  "niche_registry": {
    "general": "default_profile.json",
    "horror": "dark_mystery_profile.json",
    "dark_mystery": "dark_mystery_profile.json",
    "psychological": "dark_mystery_profile.json",
    "storytelling": "dark_mystery_profile.json"
  },
  "audience": {
    "primary": "Short-form viewers seeking high-retention, niche-relevant value or emotion",
    "psychographic": "scroll-stoppers, commenters, savers, and series followers",
    "avoid": "generic mass-audience fluff with no niche specificity"
  },
  "content_format": {
    "format": "short-form vertical video",
    "orientation": "9:16",
    "default_duration_seconds": 30,
    "min_duration_seconds": 15,
    "max_duration_seconds": 58,
    "clip_count": 3,
    "clip_duration_seconds": 10,
    "must_be_connected_clips": true,
    "clips_continue_each_other_visually": true
  },
  "tone_rules": {
    "primary_tone": "clear, specific, audience-native, retention-first",
    "secondary_tone": "curiosity-led, emotionally intentional, non-generic",
    "voice_style": "direct, concrete, platform-native; show don't lecture",
    "pacing": "hook immediately, escalate value or tension, land payoff before drop-off",
    "emotional_targets": [
      "curiosity",
      "surprise",
      "desire",
      "belonging",
      "urgency"
    ],
    "must_include": [
      "one concrete detail that anchors the video to this niche",
      "one reason the viewer should care in the first 3 seconds",
      "one payoff that matches the hook promise"
    ],
    "must_avoid": [
      "generic AI phrasing",
      "vague advice with no specifics",
      "clickbait with no delivery",
      "tone that does not match the declared niche"
    ]
  },
  "visual_dna": {
    "core_aesthetic": "niche-appropriate, clean subject focus, mobile-first framing",
    "color_palette": [],
    "lighting": [
      "subject-readable lighting",
      "consistent look across clips"
    ],
    "camera_language": [
      "close-up for emotion or detail",
      "medium shot for context",
      " purposeful camera movement only"
    ],
    "locations_preferred": [],
    "character_consistency": {
      "rule": "keep subject identity and wardrobe consistent within an episode unless the beat requires change",
      "face_reveal_policy": "show the subject clearly when trust or emotion matters for the niche"
    },
    "props_and_symbols": [],
    "forbidden_visuals": [
      "unreadable cluttered frames",
      "off-niche stock aesthetics with no story purpose"
    ]
  },
  "platform_rules": {
    "tiktok": {
      "platform_id": "tiktok",
      "display_name": "TikTok",
      "ideal_duration_seconds": {
        "min": 21,
        "max": 34,
        "sweet_spot": 28
      },
      "hook_window_seconds": 1.5,
      "caption_style": "short, native, 1-2 lines",
      "title_style": "in-video text first",
      "hashtag_count": {
        "min": 3,
        "max": 6
      },
      "cta_style": "comment, follow, or part 2 when serial",
      "audio_priority": "immediate clarity; strong opening sound or voice",
      "pacing_note": "fastest hook; motion in frame 0"
    },
    "youtube_shorts": {
      "platform_id": "youtube_shorts",
      "display_name": "YouTube Shorts",
      "ideal_duration_seconds": {
        "min": 30,
        "max": 58,
        "sweet_spot": 42
      },
      "hook_window_seconds": 2.5,
      "caption_style": "searchable first line plus supporting detail",
      "title_style": "curiosity title with one concrete noun",
      "hashtag_count": {
        "min": 2,
        "max": 5
      },
      "cta_style": "follow for more / full context in comments",
      "audio_priority": "clear narration with light bed",
      "pacing_note": "one extra setup beat allowed if retention stays dense"
    },
    "instagram_reels": {
      "platform_id": "instagram_reels",
      "display_name": "Instagram Reels",
      "ideal_duration_seconds": {
        "min": 15,
        "max": 30,
        "sweet_spot": 24
      },
      "hook_window_seconds": 1.0,
      "caption_style": "minimal, aesthetic, one strong line",
      "title_style": "cover frame and first caption line carry the hook",
      "hashtag_count": {
        "min": 4,
        "max": 8
      },
      "cta_style": "save this / series continues",
      "audio_priority": "visual-first; music or voice supports mood",
      "pacing_note": "strongest visual hook in frame 0"
    }
  },
  "hook_rules": {
    "enabled_hook_classes": [
      "violation",
      "incomplete_truth",
      "personal_threat",
      "moral_discomfort",
      "false_safety",
      "open_loop_seed"
    ],
    "hook_class_definitions": {
      "violation": "Open with something that breaks the viewer's expectation of normal.",
      "incomplete_truth": "State a partial fact that implies a larger unseen payoff.",
      "personal_threat": "Make the viewer feel the scenario could apply to them.",
      "moral_discomfort": "Present a tension that feels ethically or emotionally wrong.",
      "false_safety": "Start normal, then rupture with one precise wrong detail.",
      "open_loop_seed": "End the hook on a question the viewer needs answered."
    },
    "rotation_rules": {
      "max_consecutive_same_class": 2,
      "force_class_rotation_every_n_briefs": 5,
      "require_sensory_anchor_in_hook": false
    },
    "minimum_scores": {
      "curiosity_gap_score": 65,
      "interrupt_power": 70,
      "specificity_score": 60,
      "composite_hook_score": 68
    },
    "hook_length": {
      "max_words": 22,
      "preferred_words": "10-18",
      "max_sentences": 2
    },
    "must_include_one_of": [
      "specific time",
      "specific object",
      "specific place detail",
      "specific relationship",
      "specific result"
    ]
  },
  "story_modes": {
    "enabled_modes": [
      "quick_tip",
      "storytime",
      "comparison",
      "myth_busting",
      "before_after",
      "lore_episode"
    ],
    "mode_definitions": {
      "quick_tip": "One high-value insight delivered fast with proof or demo.",
      "storytime": "Narrative arc with setup, turn, and payoff.",
      "comparison": "Contrast two options, paths, or outcomes.",
      "myth_busting": "Challenge a common belief in the niche.",
      "before_after": "Transformation or reveal across the runtime.",
      "lore_episode": "Serialized installment with continuity callbacks."
    },
    "rotation_rules": {
      "max_consecutive_same_mode": 3,
      "require_mode_diversity_every_n_briefs": 6
    },
    "act_structure": {
      "act_1": {
        "label": "hook_beat",
        "start_second": 0,
        "end_second": 3,
        "goal": "pattern interrupt plus immediate stakes"
      },
      "act_2": {
        "label": "escalation_beats",
        "start_second": 3,
        "end_second": 20,
        "goal": "deliver value or tension in rising beats"
      },
      "act_3": {
        "label": "payoff_beat",
        "start_second": 20,
        "end_second": 45,
        "goal": "payoff that satisfies or strategically subverts the hook"
      },
      "tag": {
        "label": "loop_seed",
        "start_second": 45,
        "end_second": 60,
        "goal": "open loop for comments, saves, or next episode"
      }
    },
    "reveal_types_allowed": [
      "result_reveal",
      "comparison_reveal",
      "twist_reveal",
      "proof_reveal",
      "emotional_reveal",
      "open_loop_reveal"
    ],
    "reveal_types_forbidden": [
      "promise_hook_with_no_payoff",
      "random_unrelated_ending"
    ]
  },
  "retention_rules": {
    "minimum_retention_score": 65,
    "max_seconds_without_beat": 5,
    "minimum_pattern_breaks": 2,
    "require_loop_seed": true,
    "require_aftershock": false,
    "beat_blocks": [
      {
        "block_label": "visual_hook",
        "start_second": 0,
        "end_second": 1,
        "mechanic": "pattern_interrupt",
        "required": true,
        "implementation": "Motion, contrast, or subject focus in frame 0"
      },
      {
        "block_label": "verbal_hook_completion",
        "start_second": 1,
        "end_second": 3,
        "mechanic": "curiosity_gap",
        "required": true,
        "implementation": "Complete the hook promise in one line or text card"
      },
      {
        "block_label": "micro_payoff_1",
        "start_second": 3,
        "end_second": 8,
        "mechanic": "small_reveal",
        "required": true,
        "implementation": "First value beat, detail, or story turn"
      },
      {
        "block_label": "pattern_break_1",
        "start_second": 8,
        "end_second": 15,
        "mechanic": "perspective_shift",
        "required": true,
        "implementation": "Angle, scene, or information shift"
      },
      {
        "block_label": "escalation_ladder",
        "start_second": 15,
        "end_second": 25,
        "mechanic": "stakes_increase",
        "required": true,
        "implementation": "Raise stakes, proof, or emotional intensity"
      },
      {
        "block_label": "climax_beat",
        "start_second": 25,
        "end_second": 35,
        "mechanic": "peak_moment",
        "required": true,
        "implementation": "Main payoff, reveal, or emotional peak"
      },
      {
        "block_label": "loop_hook",
        "start_second": 35,
        "end_second": 60,
        "mechanic": "open_loop",
        "required": true,
        "implementation": "CTA, sequel seed, or comment driver"
      }
    ],
    "retention_mechanics_library": [
      "pattern_interrupt",
      "curiosity_gap",
      "perspective_shift",
      "sound_drop",
      "false_resolution",
      "object_focus",
      "countdown_pressure",
      "social_proof_tease",
      "rule_violation",
      "aftershock_silence"
    ]
  },
  "scoring_thresholds": {
    "viral_gate_minimum": 65,
    "auto_proceed_minimum": 80,
    "human_review_range": {
      "min": 65,
      "max": 79
    },
    "production_tiers": {
      "S": {
        "min_score": 85,
        "label": "flagship"
      },
      "A": {
        "min_score": 75,
        "max_score": 84,
        "label": "standard_publish"
      },
      "B": {
        "min_score": 65,
        "max_score": 74,
        "label": "revise_one_dimension"
      },
      "F": {
        "max_score": 64,
        "label": "discard"
      }
    },
    "dimension_weights": {
      "hook_strength": 0.2,
      "retention_architecture": 0.25,
      "emotional_intensity_curve": 0.15,
      "specificity": 0.1,
      "uniqueness": 0.15,
      "platform_fit": 0.1,
      "loop_potential": 0.05
    },
    "dimension_minimums": {
      "hook_strength": 65,
      "retention_architecture": 65,
      "emotional_intensity_curve": 55,
      "specificity": 60,
      "uniqueness": 65,
      "platform_fit": 55,
      "loop_potential": 45
    }
  },
  "uniqueness_rules": {
    "uniqueness_gate_minimum_score": 65,
    "max_similarity_threshold": 0.72,
    "layers": [
      {
        "layer_name": "topic_similarity",
        "threshold": 0.72,
        "lookback_count": 50,
        "method": "normalized_topic_jaccard"
      },
      {
        "layer_name": "hook_fingerprint",
        "threshold": 0.68,
        "lookback_count": 40,
        "method": "hook_class_plus_structure_hash"
      },
      {
        "layer_name": "beat_sequence_fingerprint",
        "threshold": 0.7,
        "lookback_count": 30,
        "method": "story_beat_sequence_hash"
      },
      {
        "layer_name": "generic_pattern_detection",
        "threshold": 0.0,
        "lookback_count": 0,
        "method": "banned_phrase_and_cliche_structure_scan"
      }
    ],
    "diversity_enforcement": {
      "rotate_hook_classes": true,
      "rotate_story_modes": true,
      "rotate_reveal_types": true,
      "require_unique_sensory_anchor": false,
      "require_unique_primary_object": false
    },
    "regeneration_directives": {
      "topic_collision": "Change topic angle; keep hook structure if strong.",
      "hook_collision": "Keep topic; change hook class and opening.",
      "beat_collision": "Keep hook; rebuild escalation beats.",
      "generic_pattern_hit": "Rewrite with niche-specific concrete detail."
    }
  },
  "lore_continuity_rules": {
    "enabled": false,
    "universe_id": null,
    "series_support": false,
    "character_rules": [],
    "location_rules": [],
    "artifact_rules": [],
    "timeline_rules": [],
    "hard_constraints": [],
    "breadcrumb_requirements": {
      "min_per_lore_episode": 0,
      "max_unpaid_breadcrumbs_before_payoff": 0
    }
  },
  "banned_generic_patterns": {
    "banned_phrases": [
      "what happened next will shock you",
      "you won't believe what happened",
      "make sure to like and subscribe",
      "this changed my life forever",
      "AI generated",
      "as an AI"
    ],
    "banned_structures": [
      "hook with no payoff",
      "generic advice with no proof or detail",
      "three unrelated points with no narrative spine",
      "copy-paste template cadence with no niche voice"
    ],
    "ai_tell_patterns": [
      "over-explaining the conclusion",
      "listing emotions instead of showing them",
      "perfectly generic sentences with no niche specificity",
      "vague descriptions with no concrete anchor"
    ],
    "required_originality_signals": [
      "at least one niche-specific detail per brief",
      "one line that would not fit a generic template",
      "one concrete object, result, or identifier"
    ]
  },
  "seo_and_packaging": {
    "title_rules": {
      "max_characters": 80,
      "must_contain_concrete_noun": true,
      "avoid_clickbait_spam": true,
      "preferred_patterns": [
        "[specific subject] + [result or tension]",
        "[niche problem] + [promise]",
        "[before state] + [after state]"
      ]
    },
    "hashtag_rules": {
      "mix": [
        "broad_niche",
        "sub_niche",
        "platform_discovery",
        "series_tag"
      ],
      "forbidden": [
        "single-word spam tags with no story relevance"
      ]
    },
    "thumbnail_psychology": {
      "must_show": [
        "clear focal subject",
        "one incomplete information element",
        "readable contrast on mobile"
      ],
      "must_avoid": [
        "text-only thumbnail with no visual tension",
        "full payoff reveal in thumbnail"
      ]
    }
  },
  "example_seed_topics": [],
  "metadata": {
    "created_for": "Viral Content Brain V1",
    "profile_role": "base",
    "compatible_schema": "content_brain/schemas/content_brief.py",
    "does_not_replace": "config/content_factory_profile.json",
    "notes": "Default base profile for any niche. Specialized profiles extend this file."
  }
}
