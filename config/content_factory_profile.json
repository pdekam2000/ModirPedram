    "avoid_fake_guarantees": true,
    "include_disclaimer_when_needed": true
  },
  "seo_rules": {
    "title_style": "clear, searchable, curiosity-based",
    "description_style": "short, helpful, keyword-rich",
    "hashtag_style": "mix broad, niche, and viral hashtags"
  },
  "example_topics": [
